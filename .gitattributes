###############################################################################
# GitHub Linguist
###############################################################################

# Count SQL in language statistics
*.sql linguist-language=SQL
*.sql linguist-detectable=true
*.sql text

###############################################################################
# Ignore generated files
###############################################################################

**/target/** linguist-generated=true
**/logs/** linguist-generated=true

###############################################################################
# Ignore virtual environments
###############################################################################

venv/** linguist-vendored
.venv/** linguist-vendored
depi_venv/** linguist-vendored

###############################################################################
# Ignore Python cache
###############################################################################

**/__pycache__/** linguist-generated=true
*.pyc linguist-generated=true

###############################################################################
# Ignore IDE
###############################################################################

.vscode/** linguist-vendored
.idea/** linguist-vendored